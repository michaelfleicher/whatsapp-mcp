group-jids.json

# --- Python caches ---
__pycache__/
*.pyc
.pytest_cache/
pytest-cache-files-*/

# --- Compiled bridge binary (build artifact; rebuild with `go build`) ---
whatsapp-bridge/whatsapp-client

# --- Personal automation (kept local, not published) ---
# launchd job + daily-leads scripts hardcode machine-specific paths / IDs.
launchd/
scripts/

# --- OS cruft ---
.DS_Store
